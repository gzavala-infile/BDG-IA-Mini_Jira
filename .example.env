# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL  →  Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (bypasses RLS) — NUNCA exponerla al cliente
# Supabase dashboard → Settings → API → sercdvice_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Required — origin of the frontend app (e.g. https://app.example.com)
FRONTEND_ORIGIN=http://localhost:5173

# ── OpenAPI docs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
